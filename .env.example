# Frontend defaults for artifacts/cosmos-forge
PORT=5173
BASE_PATH=/

# API server only. The frontend game does not require this for local play.
# DATABASE_URL=postgres://user:password@localhost:5432/cosmos_forge
# LOG_LEVEL=info
# PORT=5000

# Daily universe emails. Without RESEND_API_KEY, emails are written to
# artifacts/api-server/.data/universe-email-outbox.jsonl in local dev.
# RESEND_API_KEY=re_xxxxxxxxx
# UNIVERSE_EMAIL_FROM=Cosmos Forge <hello@yourdomain.com>
# UNIVERSE_EMAIL_INTERVAL_MS=86400000
